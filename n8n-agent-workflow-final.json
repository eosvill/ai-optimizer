        {
            "parameters": {
                "jsCode": "const items = $input.all();\nlet output = items[0].json.output || '';\nlet closeSession = false;\n\nif (output.includes('[CERRAR_SESION]')) {\n    closeSession = true;\n    output = output.replace('[CERRAR_SESION]', '').trim();\n}\n\nitems[0].json.output_clean = output;\nitems[0].json.closeSession = closeSession;\nreturn items;"
            },
