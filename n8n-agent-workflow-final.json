        {
            "parameters": {
                "jsCode": "const webhookData = $input.all()[0].json;\nconst remoteJid = webhookData.body.data.key.remoteJid;\n\n// Manejador de estado de Sesión\nconst staticData = $getWorkflowStaticData('global');\nstaticData.sessions = staticData.sessions || {};\n\n// Inyectar estado en primer nivel del json\nreturn [{\n  json: {\n    ...webhookData,\n    remoteJid: remoteJid,\n    hasSession: staticData.sessions[remoteJid] ? true : false\n  }\n}];"
            },
