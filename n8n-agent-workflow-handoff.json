                "options": {
                    "fallbackOutput": 1
                }
            },
            "id": "3be2b36a-2d3b-4654-bdee-ebbb3cfac4c8",
            "name": "Check Keyword",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 3.1,
            "position": [
                420,
                340
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst dir = '/home/node/.n8n/sessions';\nif (!fs.existsSync(dir)){\n    fs.mkdirSync(dir, { recursive: true });\n}\n\nfor (const item of $input.all()) {\n  const remoteJid = item.json.body.data.key.remoteJid;\n  const path = dir + '/' + remoteJid + '.txt';\n  fs.writeFileSync(path, 'active_session');\n}\nreturn $input.all();"
            },
            "id": "cfa3f412-fbee-41d3-a44e-379e9533a0ea",
            "name": "Create Session JS",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                720,
                220
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst dir = '/home/node/.n8n/sessions';\nconst filteredItems = [];\n\nfor (const item of $input.all()) {\n  const remoteJid = item.json.body.data.key.remoteJid;\n  const path = dir + '/' + remoteJid + '.txt';\n  \n  // Si el archivo existe, dejamos pasar el mensaje hacia la IA\n  if (fs.existsSync(path)) {\n    filteredItems.push(item);\n  }\n}\n// Si el array queda vacio, n8n detiene la ejecucion (que es lo que queremos para mensajes personales ignorados)\nreturn filteredItems;"
            },
            "id": "e4dfd8da-370c-4fae-b2d9-1ac1bbdeec6f",
            "name": "Check Session JS",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                720,
                460
            ]
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "={{ $('Webhook').item.json.body.data.message.conversation || $('Webhook').item.json.body.data.message.extendedTextMessage.text }}",
                "options": {
                    "systemMessage": "Sos Sofía, la asistente virtual de OptimaIA (agencia especializada en optimización con IA para empresas).\n\nTu único objetivo es: Agendar una \"Sesión Estratégica Gratuita de 60 minutos\" con leads que acaban de completar nuestro Diagnóstico de IA.\n\nREGLAS ESTRICTAS:\n1. HORARIOS HÁBILES: Solo podés ofrecer o agendar turnos de LUNES a VIERNES, entre las 11:00 hs y las 18:00 hs (hora local Argentina UTC-3).\n2. DURACIÓN: Todos los turnos duran exactamente 60 minutos.\n3. DATOS OBLIGATORIOS: Antes de confirmar cualquier reserva en la agenda, NECESITÁS tener y confirmar con el usuario su NOMBRE y su EMAIL. \n4. VALIDACIÓN DE AGENDA: JAMÁS confirmes un turno sin antes usar tu herramienta 'CheckCalendarTool' para ver si ese espacio está libre en Google Calendar.\n\nFLUJO DE RESERVA Y FINALIZACIÓN (HAND-OFF):\n- SI SE AGENDA CON ÉXITO: Usá 'BookAppointmentTool', luego 'SendConfirmationEmail'. Inmediatamente después, despedite amablemente e INVOCA LA HERRAMIENTA 'RemoveSessionTool' para cerrar tu atención.\n- SI NO SE PUEDE AGENDAR (el usuario no quiere, da vueltas, no le sirven los horarios después de 3 intentos, o hace preguntas complejas que no podés responder): Pedí disculpas, decile que le vas a transferir la conversación a un asesor humano de OptimaIA para que lo ayude mejor, e INVOCA LA HERRAMIENTA 'RemoveSessionTool' inmediatamente para desconectarte."
                }
            },
            "id": "a4d31e97-15c2-48e2-b1ee-823eaecbd449",
            "name": "AI Agent",
            "type": "@n8n/n8n-nodes-langchain.agent",
            "typeVersion": 1.6,
            "position": [
                1000,
                340
            ]
