        {
            "parameters": {
                "name": "RemoveSessionTool",
                "description": "Llama a esta herramienta SÍ O SÍ cuando hayas terminado de agendar la reunión con éxito, O BIEN cuando el usuario no se decida a agendar o pida hablar con un humano. Esta herramienta le borra la sesión para que el Agente IA deje de responderle.",
                "jsCode": "const fs = require('fs');\nconst path = '/home/node/.n8n/sessions/' + $('Webhook').item.json.body.data.key.remoteJid + '.txt';\ntry {\n  if (fs.existsSync(path)) {\n    fs.unlinkSync(path);\n    return { success: true, message: 'La sesión se eliminó correctamente. Te has desconectado de este usuario.' };\n  }\n} catch (error) {\n  return { success: false, error: error.message };\n}\nreturn { success: true, message: 'No había sesión activa para este usuario.' };"
            },
