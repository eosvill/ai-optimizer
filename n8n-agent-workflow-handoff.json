                "name": "SendConfirmationEmail",
                "description": "Llama a esta herramienta DESPUÉS de haber agendado el turno en el Calendar para enviarle el correo oficial de bienvenida y confirmación.",
                "sendTo": "={{ $parameter.leadEmail }}",
                "subject": "¡Reserva Confirmada! Tu Sesión Estratégica con OptimaIA",
                "message": "¡Hola {{ $parameter.leadName }}!<br><br>Te confirmo que agendamos con éxito tu Sesión Estratégica Gratuita para revisar tu Diagnóstico de IA.<br><br>Ya tenés la invitación en tu calendario de Google.<br><br>¡Nos vemos pronto!<br>El equipo de OptimaIA.",
                "appendAttribution": false
            },
