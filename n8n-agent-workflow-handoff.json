                "description": "Llama a esta herramienta ANTES de confirmar cualquier turno. Recibe un rango de tiempo para revisar si hay eventos en la agenda. Retorna la lista de eventos ocupados, si devuelve vacío, está libre.",
                "workflowId": "REPLACE_WITH_SUBCALL_IF_NEEDED",
                "calendar": "primary",
                "timeMin": "={{ $parameter.startTime }}",
                "timeMax": "={{ $parameter.endTime }}",
                "operation": "getAll",
                "limit": 10
