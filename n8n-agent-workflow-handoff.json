                "name": "BookAppointmentTool",
                "description": "Llama a esta herramienta ÚNICAMENTE cuando estés seguro de que el horario está libre y tenés el email del usuario. Crea el evento de 60 minutos.",
                "calendar": "primary",
                "start": "={{ $parameter.startTime }}",
                "end": "={{ $parameter.endTime }}",
                "title": "Sesión Estratégica OptimIA - {{ $parameter.leadName }}",
                "descriptionText": "Sesión estratégica de diagnóstico de IA.\nEmail del lead: {{ $parameter.leadEmail }}",
                "attendees": [
                    "={{ $parameter.leadEmail }}"
                ],
                "operation": "create",
                "sendUpdates": "all"
